<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#07132A" android:endColor="#050D1C" android:type="linear"/>
            <corners android:radius="18dp"/>
            <stroke android:width="2dp" android:color="#68A9FF"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#071126" android:endColor="#040A16" android:type="linear"/>
            <corners android:radius="18dp"/>
            <stroke android:width="2dp" android:color="@color/outline_blue"/>
        </shape>
    </item>
</selector>