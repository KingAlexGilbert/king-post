<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="28dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:contentDescription="King Post logo"
                android:src="@drawable/header_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="King Post"
                    android:textColor="@color/accent"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="One video. Three platforms."
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_badge_gold"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/accent"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PREVIEW"
                        android:textColor="@color/accent"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check your video before posting."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="208dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_preview_frame"
                android:padding="10dp">

                <ImageView
                    android:id="@+id/videoThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Selected video thumbnail"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/thumbnailPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:padding="20dp"
                    android:text="No video selected"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </FrameLayout>

            <Button
                android:id="@+id/previewButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button"
                android:text="Play Preview"
                android:textAllCaps="false"
                android:textColor="@color/accent"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/videoName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="middle"
                android:maxLines="2"
                android:text="No video selected"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/selectVideoButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Choose Video"
                    android:textAllCaps="false"
                    android:textColor="@color/blue_accent"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/clearVideoButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Clear Video"
                    android:textAllCaps="false"
                    android:textColor="@color/blue_accent"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_badge_gold"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/accent"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CAPTION"
                        android:textColor="@color/accent"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit your caption."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <EditText
                android:id="@+id/captionInput"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_edit_text"
                android:gravity="top|start"
                android:hint="Caption and hashtags..."
                android:inputType="textCapSentences|textMultiLine"
                android:padding="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/captionCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="end"
                android:text="0 characters"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/copyCaptionButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button"
                    android:text="Copy Caption"
                    android:textAllCaps="false"
                    android:textColor="@color/accent"
                    android:textStyle="bold" />
                <Space android:layout_width="10dp" android:layout_height="1dp"/>
                <Button
                    android:id="@+id/clearCaptionButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Clear"
                    android:textAllCaps="false"
                    android:textColor="@color/blue_accent"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_badge_gold"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/accent"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POST TO"
                        android:textColor="@color/accent"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap a platform. The caption is copied automatically."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/platformWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_warning"
                android:textColor="#FFD88A"
                android:textSize="14sp"
                android:visibility="gone" />

            <Button android:id="@+id/instagramButton" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="14dp" android:background="@drawable/bg_button" android:drawableStart="@drawable/ic_social_instagram" android:drawablePadding="14dp" android:gravity="start|center_vertical" android:paddingStart="16dp" android:paddingEnd="18dp" android:text="Instagram" android:textAllCaps="false" android:textColor="@color/accent" android:textSize="17sp" android:textStyle="bold"/>
            <CheckBox android:id="@+id/instagramStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="@color/accent" android:clickable="false" android:text="Not opened yet" android:textColor="@color/text_secondary"/>
            <Button android:id="@+id/tiktokButton" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="8dp" android:background="@drawable/bg_button_secondary" android:drawableStart="@drawable/ic_social_tiktok" android:drawablePadding="14dp" android:gravity="start|center_vertical" android:paddingStart="16dp" android:paddingEnd="18dp" android:text="TikTok" android:textAllCaps="false" android:textColor="@color/blue_accent" android:textSize="17sp" android:textStyle="bold"/>
            <CheckBox android:id="@+id/tiktokStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="@color/accent" android:clickable="false" android:text="Not opened yet" android:textColor="@color/text_secondary"/>
            <Button android:id="@+id/youtubeButton" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="8dp" android:background="@drawable/bg_button" android:drawableStart="@drawable/ic_social_youtube" android:drawablePadding="14dp" android:gravity="start|center_vertical" android:paddingStart="16dp" android:paddingEnd="18dp" android:text="YouTube" android:textAllCaps="false" android:textColor="@color/accent" android:textSize="17sp" android:textStyle="bold"/>
            <CheckBox android:id="@+id/youtubeStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="@color/accent" android:clickable="false" android:text="Not opened yet" android:textColor="@color/text_secondary"/>
            <Button android:id="@+id/otherAppButton" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="10dp" android:background="@drawable/bg_button_secondary" android:drawableStart="@drawable/ic_other_apps" android:drawablePadding="14dp" android:gravity="start|center_vertical" android:paddingStart="16dp" android:paddingEnd="18dp" android:text="Other Apps" android:textAllCaps="false" android:textColor="@color/blue_accent" android:textSize="17sp" android:textStyle="bold"/>
            <Button android:id="@+id/resetProgressButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp" android:background="@drawable/bg_button_secondary" android:text="Reset opened checkmarks" android:textAllCaps="false" android:textColor="@color/blue_accent"/>
        </LinearLayout>

</LinearLayout>
</ScrollView>
